{
  "name": "rca-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend Node.js para Red de Comunidad Aeronautica (sin DB, JSON files).",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npm install --include=dev && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "ts-node-dev --transpile-only src/seed/run.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "typescript": "~5.4.5"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  }
}
