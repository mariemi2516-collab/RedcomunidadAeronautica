{
  "name": "aero-ar",
  "version": "1.0.0",
  "private": true,
  "description": "App Expo para aviación general en Argentina.",
  "main": "expo-router/entry",
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "release:preview": "npx eas build --platform all --profile preview",
    "release:android": "npx eas build --platform android --profile production",
    "release:ios": "npx eas build --platform ios --profile production",
    "submit:android": "npx eas submit --platform android --profile production",
    "submit:ios": "npx eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.27",
    "expo-clipboard": "~8.0.7",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.11",
    "expo-file-system": "^55.0.17",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.17",
    "expo-sharing": "^55.0.18",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "metro": "^0.83.3",
    "metro-config": "^0.83.3",
    "typescript": "~5.9.2"
  }
}
